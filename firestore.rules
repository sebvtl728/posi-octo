rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Questionnaires : lecture publique, écriture admin authentifié seulement
    match /questionnaires/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Dossiers : lecture publique, écriture admin authentifié seulement
    match /folders/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Sessions : lecture/écriture publique (utilisateurs créent et écrivent leurs sessions)
    match /sessions/{sessionId} {
      allow read, write: if true;

      match /messages/{messageId} {
        allow read, write: if true;
      }
    }
  }
}
